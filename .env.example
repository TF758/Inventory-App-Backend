# Example environment configuration for local development.
# Copy to .env.dev or .env.local and customize as needed.
# Do not commit real secrets.

# DjangoDJANGO_ENV=dev
DEBUG=True
DJANGO_RELOAD=1
DJANGO_SERVER=dev

# Django secret key
SECRET_KEY=change-me

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Frontend
FRONTEND_URL=http://localhost:5173

# Timezone
TIME_ZONE=America/St_Lucia

# =====================================
# Email Configuration
# =====================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# =====================================
# Database Configuration
# =====================================

DB_NAME=inventory
DB_USER=inventory
DB_PASSWORD=inventory
DB_HOST=db
DB_PORT=5432

# PostgreSQL (Docker)
POSTGRES_DB=inventory
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory

# =====================================
# Redis Configuration
# =====================================

REDIS_HOST=redis
REDIS_PORT=6379

REDIS_DB_CELERY=0
REDIS_DB_CHANNELS=1
REDIS_DB_REPORTS=2

# =====================================
# JWT Authentication
# =====================================

JWT_ACCESS_MINUTES=5
JWT_REFRESH_DAYS=1

# =====================================
# Session Configuration
# =====================================

SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12

USERSESSION_CLEANUP_CRON=0 */8 * * *
USERSESSION_EXPIRE_CRON=*/15 * * * *

SESSION_EXPIRED_RETENTION_DAYS=1
SESSION_REVOKED_RETENTION_DAYS=2

# =====================================
# API Throttling
# =====================================

THROTTLE_ANON=30/min
THROTTLE_USER=1000/hour
THROTTLE_LOGIN=10/min
THROTTLE_REFRESH=30/min
THROTTLE_EQUIPMENT=30/hour

# =====================================
# Notification Lifecycle
# =====================================

NOTIF_INFO_AUTO_READ_DAYS=1
NOTIF_WARNING_AUTO_READ_DAYS=1
NOTIF_CRITICAL_AUTO_READ_DAYS=1

# Lifetime before soft delete
NOTIF_INFO_LIFETIME_DAYS=2
NOTIF_WARNING_LIFETIME_DAYS=2
NOTIF_CRITICAL_LIFETIME_DAYS=2

# Hard purge window
NOTIF_INFO_PURGE_DAYS=1
NOTIF_WARNING_PURGE_DAYS=1
NOTIF_CRITICAL_PURGE_DAYS=1

# Scheduled jobs
NOTIF_AUTO_READ_CRON=5 */3 * * *
NOTIF_CLEANUP_CRON=20 */6 * * *
NOTIF_SOFT_DELETE_CRON=10 */4 * * *

# =====================================
# Reports / Tasks
# =====================================

REPORT_CACHE_TTL_SECONDS=900
REPORT_RETENTION_DAYS=7

TASKRUN_CLEANUP_CRON=10 */6 * * *
TASKRUN_SUCCESS_RETENTION_DAYS=1
TASKRUN_SKIPPED_RETENTION_DAYS=1
TASKRUN_FAILED_RETENTION_DAYS=3

# =====================================
# Metrics / Snapshots
# =====================================

DAILY_SYSTEM_METRICS_CRON=10 */12 * * *
SNAPSHOT_SCHEMA_VERSION=1

# =====================================
# Logging Configuration
# =====================================

LOG_LEVEL=INFO
LOG_TO_CONSOLE=false

# Log rotation
LOG_FILE_WHEN=midnight
LOG_FILE_INTERVAL=1
LOG_FILE_BACKUP_COUNT=30

LOG_ERROR_WHEN=midnight
LOG_ERROR_INTERVAL=1
LOG_ERROR_BACKUP_COUNT=30

# =====================================
# Logging Lifecycle (Celery)
# =====================================

# Archive logs after N days
LOG_ARCHIVE_AFTER_DAYS=1

# Delete archived logs after N days
LOG_DELETE_AFTER_DAYS=7

# Run archive job daily at 02:15
LOG_ARCHIVE_CRON=15 2 * * *