[run]
branch = True
relative_files = True

source =
    core
    users
    assets
    assignments
    sites
    reporting
    data_import

omit =
    */migrations/*
    */tests/*
    */factories/*
    */admin.py
    manage.py
    */management/commands/*


[report]
fail_under = 30
show_missing = True
skip_covered = True
precision = 2

exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == "__main__":
    raise NotImplementedError
    pass