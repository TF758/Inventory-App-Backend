[run]
branch = True
parallel = True

source =
    db_inventory
    inventory_metrics

omit =
    */migrations/*
    */tests/*
    */factories/*
    manage.py
    */admin.py


[report]
fail_under = 70

exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == "__main__":

show_missing = True
skip_covered = True